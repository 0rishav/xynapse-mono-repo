{
  "name": "xynapse-mono-repo",
  "version": "1.0.0",
  "description": "Xynapse Platform Monorepo",
  "private": true,
  "main": "index.js",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "identity": "npm run dev --workspace=identity-service",
    "course": "npm run dev --workspace=course-service",
